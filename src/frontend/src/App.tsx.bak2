function AboutUsSection() {
  const navigate = useNavigate();

  const serviceLinks = [
    "Exterior Construction",
    "Architectural Planning",
    "Building Construction",
    "Interior Construction",
    "Road & Infrastructure Works",
  ];

  return (
    <section
      data-ocid="about.section"
