              </button>
            ))}
          </div>

          <div className="flex items-center justify-center md:justify-start gap-3">
            <div
              className="h-px flex-1"
              style={{
                maxWidth: "80px",
                backgroundColor: "oklch(0.72 0.04 60)",
              }}
            />
            <span style={{ fontSize: "16px", color: "oklch(0.52 0.09 50)" }}>
              ✦
            </span>
            <div
              className="h-px flex-1"
              style={{
                maxWidth: "80px",
                backgroundColor: "oklch(0.72 0.04 60)",
              }}
            />
